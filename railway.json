{
  "$schema": "https://railway.app/railway.schema.json",
  "deploy": {
    "startCommand": "streamlit run ui/streamlit_app.py --server.port $PORT --server.address 0.0.0.0 --server.headless true --browser.gatherUsageStats false",
    "cronSchedule": null,
    "sleepApplication": false,
    "numReplicas": 1,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
